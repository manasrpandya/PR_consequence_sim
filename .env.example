# Local development only. Leave unset on Vercel so the browser uses same-origin /api routes.
NEXT_PUBLIC_ENGINE_URL=http://localhost:8000

# Optional server-side GitHub API token. Improves public-PR rate limits; never expose it to the browser.
GITHUB_TOKEN=

# Optional server-side OpenAI key. Without it, explanations use the deterministic fallback.
OPENAI_API_KEY=
# Exact production model for evidence-grounded explanations.
OPENAI_MODEL=gpt-5.6-sol

# Exact comma-separated frontend origins, only needed for a split deployment.
ALLOWED_ORIGINS=http://localhost:3000
# Public canonical URL, set after deployment (not a secret).
NEXT_PUBLIC_APP_URL=http://localhost:3000
