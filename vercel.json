{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "services": {
    "frontend": {
      "root": "apps/web/",
      "framework": "nextjs"
    },
    "backend": {
      "root": "services/engine/",
      "framework": "fastapi",
      "entrypoint": "app.main:app",
      "functions": {
        "app/main.py": {
          "maxDuration": 60,
          "includeFiles": "fixtures/**",
          "excludeFiles": "{tests/**,.venv/**,**/__pycache__/**,**/.pytest_cache/**,**/.mypy_cache/**,**/.ruff_cache/**}"
        }
      }
    }
  },
  "rewrites": [
    {"source": "/api/:path*", "destination": {"service": "backend"}},
    {"source": "/health", "destination": {"service": "backend"}},
    {"source": "/(.*)", "destination": {"service": "frontend"}}
  ]
}
